{
  "manifest_version": 3,
  "name": "askFinz.ai | FactLens",
  "version": "1.0",
  "description": "Empower your browsing with intelligent article analysis, context insights, and comprehensive web research.",
  "author": "askFinz part of Paul V | Holdings (info@askfinz.com)",
  "icons": {
    "16": "icons/AskFinz_symbol_black.png",
    "32": "icons/AskFinz_symbol_black.png",
    "48": "icons/AskFinz_symbol_black.png",
    "128": "icons/AskFinz_symbol_black.png"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "audio",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open FactLens",
    "default_icon": {
      "16": "icons/AskFinz_symbol_black.png",
      "32": "icons/AskFinz_symbol_black.png",
      "48": "icons/AskFinz_symbol_black.png",
      "128": "icons/AskFinz_symbol_black.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"]
    }
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8080/*",
    "https://*.run.app/*"
  ]
}
